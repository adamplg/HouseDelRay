---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/blocks/PageHero.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import ContactForm from '@/components/blocks/ContactForm.astro';
import Accordion from '@/components/blocks/Accordion.astro';
import { siteConfig } from '@/data/siteConfig';
import { getFaqItems } from '@/data/faq';

const faqItemsFr = getFaqItems('fr');
---
<PageLayout title="Contactez-Nous" headerMode="transparent" locale="fr">
  <PageHero title="Contactez-Nous" height="medium" />

  <!-- Address + Map -->
  <section class="contact-info">
    <Container>
      <div class="contact-info__grid">
        <div class="contact-info__details">
          <h2 class="contact-info__title">House of Delray<br />Tel Aviv</h2>
          <div class="contact-info__lines">
            <p>{siteConfig.contact.address}</p>
            <p>{siteConfig.contact.city}</p>
            <p>&nbsp;</p>
            <p>Tél : <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`}>{siteConfig.contact.phone}</a></p>
            <p>E-mail : <a href={`mailto:${siteConfig.contact.reservationsEmail}`}>{siteConfig.contact.reservationsEmail}</a></p>
          </div>
          <Button href="https://maps.google.com" variant="secondary" size="md">
            Itinéraire
          </Button>
        </div>
        <div class="contact-info__map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3381.6!2d34.77!3d32.06!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzLCsDAzJzM2LjAiTiAzNMKwNDYnMTIuMCJF!5e0!3m2!1sen!2s!4v1"
            width="100%"
            height="350"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation de House of Delray"
          ></iframe>
        </div>
      </div>
    </Container>
  </section>

  <!-- Contact Form -->
  <section class="contact-form-section">
    <div class="contact-form-section__bg">
      <Container>
        <div class="contact-form-section__grid">
          <div class="contact-form-section__image">
            <img src="/images/lounge.png" alt="Intérieur du House of Delray" loading="lazy" />
          </div>
          <div class="contact-form-section__form">
            <ContactForm formName="contact" locale="fr" />
          </div>
        </div>
      </Container>
    </div>
  </section>

  <!-- FAQ Intro -->
  <section class="faq-intro">
    <Container width="narrow">
      <p class="faq-intro__text text-center">
        Nous sommes toujours ravis de répondre à vos questions par téléphone ou par e-mail, mais notre FAQ pourrait bien contenir la réponse que vous cherchez.
      </p>
    </Container>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <Container>
      <Accordion items={faqItemsFr.map((item) => ({
        title: item.question,
        content: item.answer,
      }))} />
    </Container>
  </section>
</PageLayout>

<style>
  .contact-info {
    padding: var(--section-padding-y) 0;
  }

  .contact-info__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .contact-info__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .contact-info__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-lg);
  }

  .contact-info__lines {
    margin-bottom: var(--space-xl);
  }

  .contact-info__lines p {
    font-size: var(--text-sm);
    color: var(--color-charcoal-light);
    line-height: 1.8;
  }

  .contact-info__lines a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-info__map iframe {
    width: 100%;
    border-radius: var(--radius-md);
  }

  .contact-form-section__bg {
    background-color: var(--color-charcoal);
    padding: var(--space-4xl) 0;
  }

  .contact-form-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .contact-form-section__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .contact-form-section__image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .faq-intro {
    padding: var(--section-padding-y) 0 var(--space-xl);
  }

  .faq-intro__text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-charcoal);
    text-align: center;
  }

  .faq {
    padding: 0 0 var(--section-padding-y);
  }
</style>
