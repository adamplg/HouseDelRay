---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHero from '@/components/blocks/PageHero.astro';
import Container from '@/components/ui/Container.astro';
import EventCard from '@/components/blocks/EventCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const months = ['Octobre', 'Novembre', 'Décembre', 'Janvier'];

const octoberEvents = [
  { title: 'Marina Maximilian Blumin', description: "Une soirée intimiste avec Marina Maximilian Blumin — Portes à 20h, concert à 21h. Cocktails signature et places assises. Places limitées, réservé aux membres.", date: 'Mardi 23 sept.', time: '19h00' },
  { title: 'Lee Yanor', description: "Rencontre avec l'artiste plasticienne Lee Yanor. Un parcours à travers ses œuvres au fil des années, accompagné de cocktails.", date: 'Mardi 23 sept.', time: '19h00' },
  { title: 'Ciné-Club', description: "On clôture l'été au bord de la piscine avec des cocktails au coucher du soleil, des DJ sets et une ambiance décontractée. Tapas, bons cocktails et le bon mood — le tout inclus. Réservé aux membres.", date: 'Mardi 23 sept.', time: '19h00' },
  { title: 'Assaf Amdursky Live', description: "Pour le trentième anniversaire de la disparition de Benny Amdursky, son fils Assaf présente un nouveau spectacle où il interprète les chansons de son père, l'un des auteurs-compositeurs les plus marquants de sa génération.", date: 'Mardi 23 sept.', time: '19h00' },
  { title: "Fête de Fin d'Été", description: "On tire sa révérence à l'été avec cocktails au bord de la piscine, DJ sets au crépuscule et une foule bien choisie. Tapas raffinées, cocktails impeccables et une énergie unique — réservé aux membres.", date: 'Mardi 23 sept.', time: '19h00' },
];

const novemberEvents = [
  { title: 'Yasmeen Godder', description: "Pour le trentième anniversaire de la disparition de Benny Amdursky, son fils Assaf présente un spectacle inédit où il réinterprète les chansons de son père, figure incontournable de la chanson israélienne.", date: 'Mardi 23 sept.', time: '19h00' },
  { title: 'Bal Masqué', description: "On fait ses adieux à l'été avec des cocktails au bord de la piscine, des DJ sets au crépuscule et une foule triée sur le volet. Tapas, cocktails d'exception et la bonne énergie — réservé aux membres.", date: 'Mardi 23 sept.', time: '19h00' },
];
---
<PageLayout title="Événements" headerMode="solid" locale="fr">
  <PageHero title="Événements d'Octobre" height="none" />

  <!-- Month Tabs -->
  <section class="month-tabs">
    <Container>
      <div class="month-tabs__bar" role="tablist" aria-label="Mois des événements">
        {months.map((month, i) => (
          <button
            class:list={['month-tabs__tab', { 'month-tabs__tab--active': i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${month.toLowerCase()}`}
            data-month-tab={month.toLowerCase()}
          >
            {month}
          </button>
        ))}
      </div>
    </Container>
  </section>

  <!-- October Events -->
  <section class="events-list" id="panel-octobre" role="tabpanel" data-month-panel="octobre">
    <Container>
      <div class="events-list__items">
        {octoberEvents.map((event) => (
          <EventCard
            title={event.title}
            description={event.description}
            date={event.date}
            time={event.time}
            layout="horizontal"
            locale="fr"
          />
        ))}
      </div>
    </Container>
  </section>

  <!-- November Events -->
  <section class="events-list events-list--hidden" id="panel-novembre" role="tabpanel" data-month-panel="novembre" aria-hidden="true">
    <Container>
      <SectionHeading>Événements de Novembre</SectionHeading>
      <div class="events-list__items">
        {novemberEvents.map((event) => (
          <EventCard
            title={event.title}
            description={event.description}
            date={event.date}
            time={event.time}
            layout="horizontal"
            locale="fr"
          />
        ))}
      </div>
    </Container>
  </section>

  <!-- December -->
  <section class="events-list events-list--hidden" id="panel-décembre" role="tabpanel" data-month-panel="décembre" aria-hidden="true">
    <Container>
      <SectionHeading>Événements de Décembre</SectionHeading>
      <p class="events-list__empty">Aucun événement à venir. Revenez bientôt.</p>
    </Container>
  </section>

  <!-- January -->
  <section class="events-list events-list--hidden" id="panel-janvier" role="tabpanel" data-month-panel="janvier" aria-hidden="true">
    <Container>
      <SectionHeading>Événements de Janvier</SectionHeading>
      <p class="events-list__empty">Aucun événement à venir. Revenez bientôt.</p>
    </Container>
  </section>
</PageLayout>

<style>
  .month-tabs {
    padding: var(--space-md) 0;
    border-bottom: var(--border-thin);
  }

  .month-tabs__bar {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .month-tabs__tab {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    padding: var(--space-sm) 0;
    color: var(--color-warm-gray);
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .month-tabs__tab--active {
    color: var(--color-charcoal);
    border-bottom-color: var(--color-charcoal);
    font-weight: 600;
  }

  .month-tabs__tab:hover {
    color: var(--color-charcoal);
  }

  .events-list {
    padding: var(--section-padding-y) 0;
  }

  .events-list--hidden {
    display: none;
  }

  .events-list__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .events-list__empty {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-warm-gray);
    text-align: center;
    padding: var(--space-3xl) 0;
  }
</style>

<script>
  function initMonthTabs() {
    const tabs = document.querySelectorAll('[data-month-tab]');
    const panels = document.querySelectorAll('[data-month-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const month = (tab as HTMLElement).dataset.monthTab;

        // Update tabs
        tabs.forEach((t) => {
          t.classList.remove('month-tabs__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('month-tabs__tab--active');
        tab.setAttribute('aria-selected', 'true');

        // Update panels
        panels.forEach((panel) => {
          const panelMonth = (panel as HTMLElement).dataset.monthPanel;
          if (panelMonth === month) {
            panel.classList.remove('events-list--hidden');
            panel.setAttribute('aria-hidden', 'false');
          } else {
            panel.classList.add('events-list--hidden');
            panel.setAttribute('aria-hidden', 'true');
          }
        });
      });
    });
  }

  initMonthTabs();
  document.addEventListener('astro:after-swap', initMonthTabs);
</script>
