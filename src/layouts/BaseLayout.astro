---
import { ViewTransitions } from 'astro:transitions';
import SkipToContent from '@/components/global/SkipToContent.astro';
import { getAlternatePath, type Locale } from '@/i18n/utils';
import { getSiteDescription } from '@/data/siteConfig';
import '@/styles/global.css';
import '@/styles/typography.css';
import '@/styles/animations.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
  locale?: Locale;
}

const {
  title,
  ogImage = '/images/og-image.jpg',
  bodyClass = '',
  locale = 'en',
} = Astro.props;

const description = Astro.props.description ?? getSiteDescription(locale);
const canonicalUrl = new URL(Astro.url.pathname, 'https://houseofdelray.com');
const alternatePath = getAlternatePath(Astro.url.pathname, locale === 'en' ? 'fr' : 'en');
const alternateUrl = new URL(alternatePath, 'https://houseofdelray.com');
---
<!DOCTYPE html>
<html lang={locale === 'fr' ? 'fr' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | House of Delray</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="en" href={locale === 'en' ? canonicalUrl.toString() : alternateUrl.toString()} />
    <link rel="alternate" hreflang="fr" href={locale === 'fr' ? canonicalUrl.toString() : alternateUrl.toString()} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | House of Delray`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://houseofdelray.com').toString()} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="House of Delray" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | House of Delray`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://houseofdelray.com').toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Josefin+Sans:wght@300;400;600&family=Proza+Libre:wght@400;500;600&family=Poppins:wght@400;500;600&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Josefin+Sans:wght@300;400;600&family=Proza+Libre:wght@400;500;600&family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- View Transitions -->
    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    <SkipToContent locale={locale} />
    <slot />

    <!-- Scroll-triggered animations -->
    <script>
      function initScrollAnimations() {
        const elements = document.querySelectorAll('.animate-on-scroll, .animate-fade, .animate-scale');
        if (!elements.length) return;

        // Respect reduced motion
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          elements.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        elements.forEach((el) => observer.observe(el));
      }

      initScrollAnimations();
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
