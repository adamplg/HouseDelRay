---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/global/Header.astro';
import SideMenu from '@/components/global/SideMenu.astro';
import NewsletterSignup from '@/components/global/NewsletterSignup.astro';
import Footer from '@/components/global/Footer.astro';
import type { Locale } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  headerMode?: 'transparent' | 'solid' | 'dark';
  locale?: Locale;
}

const {
  title,
  description,
  ogImage,
  headerMode = 'transparent',
  locale = 'en',
} = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage} locale={locale}>
  <Header mode={headerMode} locale={locale} />
  <SideMenu locale={locale} />
  <main id="main-content">
    <slot />
  </main>
  <NewsletterSignup locale={locale} />
  <Footer locale={locale} />
</BaseLayout>
