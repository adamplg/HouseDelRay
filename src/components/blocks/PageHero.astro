---
interface Props {
  title: string;
  subtitle?: string;
  height?: 'full' | 'tall' | 'medium' | 'none';
  backgroundImage?: string;
  backgroundGradient?: string;
  videoSrc?: string;
  class?: string;
}

const {
  title,
  subtitle,
  height = 'tall',
  backgroundImage,
  backgroundGradient = 'linear-gradient(135deg, var(--color-sand) 0%, var(--color-mauve-300) 50%, var(--color-mauve-400) 100%)',
  videoSrc,
  class: className = '',
} = Astro.props;

const bgStyle = backgroundImage
  ? `background-image: linear-gradient(var(--color-overlay), var(--color-overlay)), url('${backgroundImage}');`
  : videoSrc
    ? ''
    : `background-image: ${backgroundGradient};`;
---
{height !== 'none' ? (
  <section
    class:list={['hero', `hero--${height}`, videoSrc && 'hero--video', className]}
    style={bgStyle}
    data-hero
  >
    {videoSrc && (
      <Fragment>
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          webkit-playsinline
          preload="auto"
          data-hero-video
        >
          <source src={videoSrc} type="video/mp4" />
        </video>
        <div class="hero__video-overlay"></div>
      </Fragment>
    )}
    <div class="hero__content">
      <h1 class="hero__title text-hero" set:html={title} />
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
      <slot />
    </div>
    <slot name="bottom" />
  </section>
) : (
  <section class:list={['hero', 'hero--none', className]}>
    <div class="hero__content hero__content--bar">
      <h1 class="hero__title-bar">{title}</h1>
    </div>
  </section>
)}

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .hero--full {
    min-height: 100vh;
    min-height: 100dvh;
  }

  .hero--tall {
    min-height: 70vh;
    min-height: 70dvh;
  }

  .hero--medium {
    min-height: 50vh;
    min-height: 50dvh;
  }

  .hero--none {
    min-height: auto;
    background: var(--color-cream);
    padding-top: calc(80px + var(--space-xl));
    padding-bottom: var(--space-lg);
    padding-inline: var(--section-padding-x);
  }

  /* ── Video background ── */
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video {
      display: none;
    }

    .hero--video {
      background-image: linear-gradient(135deg, var(--color-sand) 0%, var(--color-mauve-300) 50%, var(--color-mauve-400) 100%);
    }
  }

  .hero__content {
    text-align: center;
    color: var(--color-white);
    padding: var(--space-xl) var(--section-padding-x);
    max-width: none;
    z-index: 2;
    position: relative;
  }

  .hero__content--bar {
    color: var(--color-charcoal);
    text-align: left;
    max-width: 1200px;
    margin-inline: auto;
    width: 100%;
  }

  .hero__title {
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .hero__title-bar {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: rgba(255, 255, 255, 0.9);
    max-width: 550px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .hero--full {
      min-height: 100vh;
    }

    .hero--tall {
      min-height: 80vh;
    }
  }
</style>

<script>
  function initHeroVideos() {
    document.querySelectorAll<HTMLVideoElement>('[data-hero-video]').forEach((video) => {
      video.muted = true;
      video.playsInline = true;
      video.play().catch(() => {});
    });
  }

  initHeroVideos();
  document.addEventListener('astro:after-swap', initHeroVideos);
</script>
