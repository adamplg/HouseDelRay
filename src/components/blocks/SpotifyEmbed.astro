---
interface Props {
  playlistId?: string;
  theme?: 'light' | 'dark';
}

const {
  playlistId = '37i9dQZF1DXcBWIGoYBM5M',
  theme = 'dark',
} = Astro.props;

const src = `https://open.spotify.com/embed/playlist/${playlistId}?utm_source=generator&theme=${theme === 'dark' ? '0' : '1'}`;
---
<div class="spotify-embed">
  <iframe
    src={src}
    width="100%"
    height="352"
    frameborder="0"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    title="Spotify playlist"
  ></iframe>
</div>

<style>
  .spotify-embed {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--space-xl) var(--section-padding-x);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .spotify-embed iframe {
    border-radius: var(--radius-lg);
  }
</style>
