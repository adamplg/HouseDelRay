---
interface Props {
  title: string;
  excerpt?: string;
  date?: string;
  author?: string;
  image?: string;
  link: string;
  variant?: 'standard' | 'featured';
  tags?: string[];
}

const {
  title,
  excerpt,
  date,
  author,
  image = '/images/placeholder.svg',
  link,
  variant = 'standard',
  tags = [],
} = Astro.props;
---
<article class:list={['article-card', `article-card--${variant}`]}>
  <a href={link} class="article-card__link">
    <div class="article-card__image img-hover-zoom">
      <img src={image} alt={title} loading="lazy" />
    </div>
    <div class="article-card__content">
      <h3 class="article-card__title">{title}</h3>
      {(date || author) && (
        <div class="article-card__meta">
          {tags.length > 0 && (
            <span class="article-card__tags">{tags.join(' / ')}</span>
          )}
          {date && <span class="article-card__date">{date}</span>}
        </div>
      )}
      {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
    </div>
  </a>
</article>

<style>
  .article-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .article-card__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .article-card__content {
    padding-top: var(--space-md);
  }

  .article-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: var(--leading-snug);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .article-card__meta {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .article-card__tags,
  .article-card__date {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .article-card__excerpt {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-charcoal-light);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Featured Variant ── */
  .article-card--featured {
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .article-card--featured .article-card__link {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      align-items: center;
    }

    .article-card--featured .article-card__content {
      padding-top: 0;
    }
  }

  .article-card--featured .article-card__image img {
    aspect-ratio: 4 / 3;
  }

  .article-card--featured .article-card__title {
    font-size: var(--text-3xl);
  }
</style>
