---
interface Props {
  title: string;
  imageLeft?: string;
  imageRight?: string;
  link?: string;
}

const {
  title,
  imageLeft = '/images/placeholder.svg',
  imageRight = '/images/placeholder.svg',
  link,
} = Astro.props;

const Tag = link ? 'a' : 'div';
---
<section class="two-images">
  <Tag class="two-images__grid" {...link ? { href: link } : {}}>
    <div class="two-images__left img-hover-zoom">
      <img src={imageLeft} alt={title} loading="lazy" />
      <div class="two-images__overlay">
        <h2 class="two-images__title text-hero">{title}</h2>
      </div>
    </div>
    <div class="two-images__right img-hover-zoom">
      <img src={imageRight} alt="" loading="lazy" />
    </div>
  </Tag>
</section>

<style>
  .two-images__grid {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
  }

  @media (min-width: 768px) {
    .two-images__grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  .two-images__left {
    position: relative;
  }

  .two-images__left img,
  .two-images__right img {
    width: 100%;
    height: 100%;
    min-height: 300px;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .two-images__left img,
    .two-images__right img {
      min-height: 500px;
    }
  }

  .two-images__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-overlay);
  }

  .two-images__title {
    color: var(--color-white);
    font-size: var(--text-3xl);
    text-align: center;
  }
</style>
