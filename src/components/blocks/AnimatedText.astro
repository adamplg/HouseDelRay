---
interface TextSegment {
  text: string;
  highlight?: boolean;
}

interface Props {
  segments: TextSegment[];
}

const { segments } = Astro.props;
---
<div class="animated-text speakeasy-animated-text" data-animated-text>
  <p>
    {segments.map((seg) => (
      seg.highlight ? (
        <span class="highlight">{seg.text}</span>
      ) : (
        <span class="regular">{seg.text}</span>
      )
    ))}
  </p>
</div>

<style>
  .animated-text {
    padding: var(--space-4xl) var(--section-padding-x);
    text-align: center;
  }

  .animated-text p {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    text-transform: uppercase;
    max-width: 800px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .animated-text p {
      font-size: var(--text-3xl);
    }
  }

  .highlight {
    color: var(--color-magenta);
    font-weight: 600;
  }

  .regular {
    color: rgba(250, 248, 245, 0.6);
    font-weight: 300;
  }
</style>
