---
import Button from '@/components/ui/Button.astro';
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  date?: string;
  time?: string;
  image?: string;
  rsvpLink?: string;
  layout?: 'horizontal' | 'vertical';
  locale?: Locale;
}

const {
  title,
  description,
  date,
  time,
  image = '/images/placeholder.svg',
  rsvpLink = '#rsvp',
  layout = 'horizontal',
  locale = 'en',
} = Astro.props;
const t = useTranslations(locale);
---
<article class:list={['event-card', `event-card--${layout}`]}>
  <div class="event-card__image img-hover-zoom">
    <img src={image} alt={title} loading="lazy" />
  </div>
  <div class="event-card__content">
    <div>
      <h3 class="event-card__title">{title}</h3>
      {description && <p class="event-card__desc">{description}</p>}
      {(date || time) && (
        <div class="event-card__meta">
          {date && <span class="event-card__date">{date}</span>}
          {time && <span class="event-card__time">{time}</span>}
        </div>
      )}
    </div>
    <Button href={rsvpLink} variant="secondary" size="sm">
      {t('eventCard.rsvp')}
    </Button>
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .event-card--horizontal {
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .event-card--horizontal {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .event-card__image {
    flex-shrink: 0;
  }

  .event-card--horizontal .event-card__image {
    width: 100%;
  }

  @media (min-width: 768px) {
    .event-card--horizontal .event-card__image {
      width: 280px;
    }
  }

  .event-card__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .event-card--vertical .event-card__image img {
    aspect-ratio: 1 / 1;
  }

  .event-card__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-md);
    flex: 1;
  }

  @media (min-width: 768px) {
    .event-card--horizontal .event-card__content {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .event-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-sm);
  }

  .event-card__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-charcoal-light);
    margin-bottom: var(--space-md);
    max-width: 500px;
  }

  .event-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .event-card__date {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .event-card__time {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-warm-gray);
  }
</style>
