---
interface Props {
  width?: 'narrow' | 'default' | 'wide' | 'full';
  class?: string;
}

const { width = 'default', class: className = '' } = Astro.props;
---
<div class:list={['container', `container--${width}`, className]}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--section-padding-x);
  }

  .container--narrow {
    max-width: 780px;
  }

  .container--default {
    max-width: 1200px;
  }

  .container--wide {
    max-width: 1380px;
  }

  .container--full {
    max-width: 100%;
    padding-inline: 0;
  }
</style>
