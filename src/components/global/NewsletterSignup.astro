---
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  variant?: 'standalone' | 'dark';
  locale?: Locale;
}

const { variant = 'standalone', locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const formName = locale === 'fr' ? 'newsletter-fr' : 'newsletter';
---
<section class:list={['newsletter', `newsletter--${variant}`]}>
  <div class="newsletter__inner">
    <div class="newsletter__text">
      <h2 class="newsletter__title">
        <span class="newsletter__title-line">{t('newsletter.title.line1')}</span>
        <span class="newsletter__title-line">{t('newsletter.title.line2')} <strong>{t('newsletter.title.bold')}</strong></span>
      </h2>
    </div>

    <div class="newsletter__form-wrap">
      <p class="newsletter__description">
        {t('newsletter.description')}
      </p>

      <form class="newsletter__form" data-netlify="true" name={formName} method="POST">
        <div class="newsletter__input-group">
          <input
            type="email"
            name="email"
            placeholder={t('newsletter.placeholder')}
            required
            aria-label={t('newsletter.emailLabel')}
            class="newsletter__input"
          />
          <button type="submit" class="newsletter__submit text-ui">
            {t('newsletter.submit')}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .newsletter {
    padding: var(--space-4xl) var(--section-padding-x);
  }

  .newsletter--standalone {
    background-color: var(--color-forest);
    color: var(--color-cream);
  }

  .newsletter--dark {
    background-color: var(--color-night);
    color: var(--color-cream);
  }

  .newsletter__inner {
    max-width: 1200px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .newsletter__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3xl);
    }
  }

  /* ── Title ── */
  .newsletter__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 300;
    line-height: var(--leading-tight);
    color: var(--color-cream);
  }

  .newsletter__title strong {
    font-family: 'Poppins', var(--font-ui);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .newsletter__title-line {
    display: block;
  }

  /* ── Description ── */
  .newsletter__description {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(250, 248, 245, 0.85);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-normal);
  }

  /* ── Form ── */
  .newsletter__form-wrap {
    flex: 1;
    max-width: 500px;
  }

  .newsletter__input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .newsletter__input {
    width: 100%;
    padding: 0.75rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(250, 248, 245, 0.4);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .newsletter__input::placeholder {
    color: rgba(250, 248, 245, 0.5);
  }

  .newsletter__input:focus {
    border-bottom-color: var(--color-cream);
  }

  .newsletter__submit {
    align-self: flex-start;
    padding: 0.65rem 1.5rem;
    background-color: transparent;
    color: var(--color-cream);
    border: 1px solid var(--color-cream);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-default),
      color var(--duration-fast) var(--ease-default);
  }

  .newsletter__submit:hover {
    background-color: var(--color-cream);
    color: var(--color-forest);
  }

  .newsletter--dark .newsletter__submit:hover {
    color: var(--color-night);
  }
</style>
